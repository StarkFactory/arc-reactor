# ===========================================
# Arc Reactor - Environment Variables
# ===========================================
# Copy this file to .env:
#   cp .env.example .env
#
# IntelliJ: Add these values to Run/Debug Configuration → Environment variables.
# The .env file is included in .gitignore and will not be committed.

# =====================
# LLM Provider
# =====================
# Only providers with API keys set will be activated.
# You can set multiple keys to enable multi-provider support.

# Gemini (default) — Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI
# SPRING_AI_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Anthropic
# SPRING_AI_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# JWT auth secret (required, min 32 bytes)
# Dev example (works as-is for local run). Replace this value in shared/prod environments.
ARC_REACTOR_AUTH_JWT_SECRET=dev-only-jwt-secret-change-me-before-prod-123456
# Optional default tenant ID used in issued JWT tokens
ARC_REACTOR_AUTH_DEFAULT_TENANT_ID=default

# =====================
# Server
# =====================
SERVER_PORT=8080

# =====================
# MCP Runtime Policy (optional)
# =====================
# Default app value is "atlassian". Add "swagger" before registering the Swagger MCP server.
# ARC_REACTOR_MCP_ALLOWED_SERVER_NAMES=atlassian,swagger

# =====================
# PostgreSQL (required by default runtime preflight)
# =====================
# docker-compose.yml wires these automatically.
# For local JVM bootRun, set SPRING_DATASOURCE_URL/USERNAME/PASSWORD env vars directly.
# If RAG/document endpoints are enabled, set this to auto-create pgvector extension/table.
SPRING_AI_VECTORSTORE_PGVECTOR_INITIALIZE_SCHEMA=true
# Optional DB_* values below are used by docker-compose service defaults.
DB_PORT=5432
DB_NAME=arcreactor
DB_USER=arc
DB_PASSWORD=arc

# =====================
# Redis (optional runtime features)
# =====================
# docker-compose starts Redis automatically. Leave defaults unless you need custom ports/keys.
REDIS_PORT=6379
# Enable semantic response cache (requires EmbeddingModel + Redis)
ARC_REACTOR_CACHE_ENABLED=false
ARC_REACTOR_CACHE_SEMANTIC_ENABLED=false
# Token revocation backend: memory | jdbc | redis
ARC_REACTOR_AUTH_TOKEN_REVOCATION_STORE=memory
ARC_REACTOR_AUTH_TOKEN_REVOCATION_REDIS_KEY_PREFIX=arc:auth:revoked

# =====================
# Slack Runtime (optional)
# =====================
# Turn on only when you use Slack events or local Slack tools.
ARC_REACTOR_SLACK_ENABLED=false
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_APP_TOKEN=xapp-your-app-token
# SLACK_SIGNING_SECRET=your-signing-secret
# ARC_REACTOR_SLACK_TOOLS_ENABLED=true
# ARC_REACTOR_SLACK_TOOLS_SCOPE_AWARE_ENABLED=true
# ARC_REACTOR_SLACK_TOOLS_CONVERSATION_SCOPE_MODE=public_only

# =====================
# Companion MCP Server Hardening (optional)
# =====================
# These values are NOT consumed by Arc Reactor itself.
# They are for the upstream MCP server processes that Arc Reactor proxies through `/api/mcp/servers`.
# Reuse the same shared HMAC secret in the companion server and in the registered MCP server config.
# SWAGGER_MCP_ADMIN_TOKEN=replace-with-swagger-admin-token
# SWAGGER_MCP_ADMIN_HMAC_REQUIRED=true
# SWAGGER_MCP_ADMIN_HMAC_SECRET=replace-with-shared-hmac-secret
# SWAGGER_MCP_ADMIN_HMAC_WINDOW_SECONDS=300
# MCP_ADMIN_TOKEN=replace-with-atlassian-admin-token
# MCP_ADMIN_HMAC_REQUIRED=true
# MCP_ADMIN_HMAC_SECRET=replace-with-shared-hmac-secret
# MCP_ADMIN_HMAC_WINDOW_SECONDS=300

# =====================
# IntelliJ Configuration Example
# =====================
# Copy the following to Run/Debug Configuration → Environment variables:
#
# [Using Gemini]
# GEMINI_API_KEY=AIzaSy_your_actual_key;ARC_REACTOR_AUTH_JWT_SECRET=replace-with-32-byte-secret
#
# [Using OpenAI]
# SPRING_AI_OPENAI_API_KEY=sk-your_actual_key;ARC_REACTOR_AUTH_JWT_SECRET=replace-with-32-byte-secret
#
# [Using PostgreSQL]
# GEMINI_API_KEY=AIzaSy_your_actual_key;ARC_REACTOR_AUTH_JWT_SECRET=replace-with-32-byte-secret;SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/arcreactor;SPRING_DATASOURCE_USERNAME=arc;SPRING_DATASOURCE_PASSWORD=arc
